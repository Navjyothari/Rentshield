# ===============
# SERVER (.env)
# ===============
DATABASE_URL="postgresql://postgres:password@localhost:5432/rentshield?schema=public"
JWT_ACCESS_SECRET="your_jwt_access_secret_key_needs_to_be_long_12345"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_needs_to_be_long_12345"

CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

ANTHROPIC_API_KEY="your_anthropic_api_key_here"

PORT=5000
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# ===============
# CLIENT (.env)
# ===============
VITE_API_URL="http://localhost:5000/api"
VITE_SOCKET_URL="http://localhost:5000"
VITE_MAPBOX_TOKEN="your_mapbox_public_token_here"
